{
  "name": "@sulhadin/orchestrator",
  "version": "4.0.0-beta.1",
  "description": "AI Team Orchestration System — multi-role coordination for Claude Code",
  "bin": "bin/index.js",
  "scripts": {
    "test": "node --test test/**/*.test.js",
    "template": "node bin/build-template.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,md,yml,json}": [
      "yarn template",
      "yarn build"
    ]
  },
  "files": [
    "bin/",
    "template/"
  ],
  "keywords": [
    "claude",
    "orchestrator",
    "ai",
    "agent",
    "multi-agent",
    "claude-code",
    "team"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sulhadin/orchestrator.git"
  },
  "homepage": "https://github.com/sulhadin/orchestrator/blob/main/docs/README.md",
  "bugs": {
    "url": "https://github.com/sulhadin/orchestrator/issues"
  },
  "author": "Sulhadin Öney",
  "license": "MIT",
  "packageManager": "yarn@4.13.0",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}